# MongoDB Connection (MongoDB Atlas)
# Get from: mongodb.com/cloud → Cluster → Connect → Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/noqueue?retryWrites=true&w=majority

# Redis Connection (Upstash)
# Get from: upstash.com → Redis → Details → Redis CLI → REDIS_URL
# Format: redis://default:token@host:port
REDIS_URL=redis://default:token@host.upstash.io:port

# JWT Secret for token signing (generate: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars_long

# Firebase Configuration (for phone OTP and FCM)
# Get from: Firebase Console → Project Settings → Service Account
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server Port
PORT=3000

# Environment
NODE_ENV=development

# Optional: Cloudinary (for file uploads)
# Get from: cloudinary.com → Dashboard
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional: WhatsApp (Meta Cloud API)
# Get from: developers.facebook.com → WhatsApp Cloud API
WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# Optional: Razorpay (Payments)
# Get from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Optional: Sentry (Error tracking)
# Get from: sentry.io → Projects → DSN
SENTRY_DSN=https://key@sentry.io/project-id
